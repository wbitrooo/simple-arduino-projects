bool statoLed = false;
bool ultimoStati = LOW;
void setup(){
pinMode(2,INPUT);
pinMode(12,OUTPUT);
Serial.begin(9600);
}
void loop(){
 int no = digitalRead(2);
 Serial.println(no);
 delay(1);
if(no==0 and ultimoStati ==LOW){
  statoLed =!statoLed;
  digitalWrite(12,statoLed);
}
delay(200);
ultimoStati=no;
}

